# Git attributes file for proper handling of line endings and language detection

# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files
*.c text
*.cpp text
*.h text
*.java text
*.py text
*.rb text
*.sh text
*.css text
*.html text
*.xml text
*.json text

# Declare binary files
*.jpg binary
*.png binary
*.gif binary
*.zip binary

# Language detection
*.py linguist-language=Python
*.js linguist-language=JavaScript
*.html linguist-language=HTML
*.css linguist-language=CSS